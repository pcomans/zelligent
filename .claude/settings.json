{
  "permissions": {
    "allow": [
      "Bash(bash test.sh:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-push-block.sh"
          }
        ]
      }
    ]
  }
}
